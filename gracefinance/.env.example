# GraceFinance Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gracefinance

# JWT Authentication
SECRET_KEY=your-secret-key-change-this-to-something-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_tier_price_id
STRIPE_PRICE_PREMIUM=price_your_premium_tier_price_id

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
